  "html": "<!DOCTYPE html>\n<html>\n<head><meta charset=\"utf-8\"></head>\n<body style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; background: #f4f5f7;\">\n\n<div style=\"background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); padding: 30px; border-radius: 12px 12px 0 0;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>\n    <td><h1 style=\"color: #e94560; margin: 0; font-size: 22px;\">{{emoji}} {{headline}}</h1></td>\n  </tr></table>\n  <p style=\"color: #a8a8b3; margin: 8px 0 0; font-size: 14px;\">{{personality_name}} | {{personality_title}} | BroadFSC</p>\n</div>\n\n<div style=\"background: #ffffff; padding: 25px; border: 1px solid #e0e0e0; border-top: none;\">\n  <p style=\"font-size: 16px; line-height: 1.6; color: #333;\">Hi {{first_name}},</p>\n\n  <p style=\"font-size: 15px; line-height: 1.7; color: #444;\">{{opening_paragraph}}</p>\n\n  <div style=\"background: #f8f9fa; border-left: 4px solid #e94560; padding: 15px; margin: 20px 0; border-radius: 0 8px 8px 0;\">\n    <p style=\"margin: 0; font-size: 14px; color: #555;\"><strong>Key Takeaway:</strong> {{key_takeaway}}</p>\n  </div>\n\n  <p style=\"font-size: 15px; line-height: 1.7; color: #444;\">{{analysis_paragraph}}</p>\n\n  <!-- PRIMARY CTA: Visit Website -->\n  <div style=\"text-align: center; margin: 30px 0 10px;\">\n    <a href=\"https://www.broadfsc.com/different\" style=\"background: linear-gradient(135deg, #e94560, #c23152); color: white; padding: 16px 40px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 16px; display: inline-block; box-shadow: 0 4px 15px rgba(233,69,96,0.3);\">Visit BroadFSC →</a>\n  </div>\n  <p style=\"text-align: center; font-size: 13px; color: #888; margin: 5px 0 25px;\">Licensed & Regulated Investment Advisory</p>\n\n  <!-- SECONDARY CTA: Direct Contact -->\n  <div style=\"background: #f0f4ff; border: 1px solid #d0d8f0; border-radius: 8px; padding: 18px; margin: 20px 0; text-align: center;\">\n    <p style=\"margin: 0 0 10px; font-size: 14px; color: #333;\"><strong>Want personalized insights?</strong></p>\n    <p style=\"margin: 0 0 12px; font-size: 13px; color: #666;\">Reply to this email or contact us directly:</p>\n    <a href=\"mailto:msli2233bin@gmail.com\" style=\"background: #1a1a2e; color: white; padding: 10px 24px; border-radius: 6px; text-decoration: none; font-weight: bold; font-size: 14px; display: inline-block;\">📧 Contact Us Directly</a>\n  </div>\n\n  <p style=\"font-size: 14px; line-height: 1.6; color: #666;\">{{sign_off}}</p>\n</div>\n\n<div style=\"background: #1a1a2e; padding: 18px 25px; border-radius: 0 0 12px 12px; text-align: center;\">\n  <p style=\"color: #a8a8b3; font-size: 12px; margin: 0;\"><a href=\"https://www.broadfsc.com/different\" style=\"color: #e94560; text-decoration: none;\">Broad Investment Securities</a> | Licensed & Regulated</p>\n  <p style=\"color: #666; font-size: 11px; margin: 5px 0 0;\">This is not financial advice. Past performance does not guarantee future results.</p>\n</div>\n\n</body>\n</html>"
