  "html": "<!DOCTYPE html>\n<html>\n<head><meta charset=\"utf-8\"></head>\n<body style=\"margin:0; padding:20px; background-color:#f4f5f7; font-family:Arial,sans-serif;\">\n\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:600px; margin:0 auto;\">\n<!-- HEADER -->\n<tr><td style=\"background-color:#1a1a2e; padding:28px 30px; border-radius:12px 12px 0 0;\">\n  <h1 style=\"color:#e94560; margin:0; font-size:22px;\">{{emoji}} {{headline}}</h1>\n  <p style=\"color:#a8a8b3; margin:8px 0 0; font-size:14px;\">{{personality_name}} | {{personality_title}} | BroadFSC</p>\n</td></tr>\n\n<!-- BODY -->\n<tr><td style=\"background-color:#ffffff; padding:28px 30px; border-left:1px solid #e0e0e0; border-right:1px solid #e0e0e0;\">\n  <p style=\"font-size:16px; line-height:1.6; color:#333; margin:0 0 12px;\">Hi {{first_name}},</p>\n  <p style=\"font-size:15px; line-height:1.7; color:#444; margin:0 0 16px;\">{{opening_paragraph}}</p>\n\n  <!-- KEY TAKEAWAY -->\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin:20px 0;\"><tr>\n    <td style=\"background-color:#f8f9fa; border-left:4px solid #e94560; padding:15px; border-radius:0 8px 8px 0;\">\n      <p style=\"margin:0; font-size:14px; color:#555;\"><strong>Key Takeaway:</strong> {{key_takeaway}}</p>\n    </td>\n  </tr></table>\n\n  <p style=\"font-size:15px; line-height:1.7; color:#444; margin:0 0 16px;\">{{analysis_paragraph}}</p>\n  <p style=\"font-size:15px; line-height:1.7; color:#444; margin:0 0 24px;\">{{action_paragraph}}</p>\n\n  <!-- PRIMARY CTA: Visit Website -->\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"text-align:center; padding:10px 0;\">\n    <a href=\"https://www.broadfsc.com/different\" style=\"background-color:#e94560; color:#ffffff; padding:16px 40px; border-radius:8px; text-decoration:none; font-weight:bold; font-size:16px; display:inline-block;\">Visit BroadFSC &rarr;</a>\n  </td></tr>\n  <tr><td style=\"text-align:center; padding:5px 0 24px;\">\n    <p style=\"font-size:13px; color:#888; margin:0;\">Licensed &amp; Regulated Investment Advisory</p>\n  </td></tr></table>\n\n  <!-- SECONDARY CTA: Direct Contact -->\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#eef2ff; border:1px solid #d0d8f0; border-radius:8px;\"><tr><td style=\"padding:18px; text-align:center;\">\n    <p style=\"margin:0 0 8px; font-size:14px; color:#333;\"><strong>Want personalized insights?</strong></p>\n    <p style=\"margin:0 0 12px; font-size:13px; color:#666;\">Reply to this email or contact us directly:</p>\n    <a href=\"mailto:msli2233bin@gmail.com\" style=\"background-color:#1a1a2e; color:#ffffff; padding:10px 24px; border-radius:6px; text-decoration:none; font-weight:bold; font-size:14px; display:inline-block;\">Contact Us Directly</a>\n  </td></tr></table>\n\n  <p style=\"font-size:14px; line-height:1.6; color:#666; margin:24px 0 0;\">{{sign_off}}</p>\n</td></tr>\n\n<!-- FOOTER -->\n<tr><td style=\"background-color:#1a1a2e; padding:18px 30px; border-radius:0 0 12px 12px; text-align:center;\">\n  <p style=\"color:#a8a8b3; font-size:12px; margin:0;\"><a href=\"https://www.broadfsc.com/different\" style=\"color:#e94560; text-decoration:none;\">Broad Investment Securities</a> | Licensed &amp; Regulated</p>\n  <p style=\"color:#666; font-size:11px; margin:5px 0 0;\">This is not financial advice. Past performance does not guarantee future results.</p>\n</td></tr>\n</table>\n\n</body>\n</html>"
